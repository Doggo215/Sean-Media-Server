# Sean Home — environment variables
# Copy to .env and fill in values. Never commit .env to git.
#
# Jellyfin API key: Admin → Dashboard → API Keys → New Key (name: SeanHome)
JELLYFIN_API_KEY=your_api_key_here
# Jellyfin user ID: visible in Admin → Users → click user → URL bar
JELLYFIN_USER_ID=your_user_id_here
# Jellyfin base URL (localhost since Sean Home runs on the same Pi)
JELLYFIN_URL=http://127.0.0.1:8096

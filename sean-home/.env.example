# Sean Home — environment variables
# Copy to .env and fill in values. Never commit .env to git.
#
# Jellyfin API key: Admin → Dashboard → API Keys → New Key (name: SeanHome)
JELLYFIN_API_KEY=your_api_key_here
# Jellyfin user ID: visible in Admin → Users → click user → URL bar
JELLYFIN_USER_ID=your_user_id_here
# Jellyfin base URL (localhost since Sean Home runs on the same Pi)
JELLYFIN_URL=http://127.0.0.1:8096

# ── Home Assistant / PS5 (optional) ──────────────────────────────────────────
# Leave all blank to use the safe PS5 placeholder. Fill in to enable live data.
#
# Home Assistant URL (local network address)
HOME_ASSISTANT_URL=http://homeassistant.local:8123
# Long-lived access token: HA → Profile → Security → Long-Lived Access Tokens
HOME_ASSISTANT_TOKEN=
#
# Entity IDs depend on which HA integration you use:
#   Official PlayStation Network integration: Settings → Devices → PlayStation Network
#   The main entity is typically a media_player (state: idle / playing / off)
#   A HACS PSN integration may expose separate sensor entities for game and friends
#
# Primary PS5 entity (media_player or sensor showing online/offline/playing state)
HA_PS5_STATUS_ENTITY=
# Optional: entity whose state is the current game/app name
HA_PS5_CURRENT_GAME_ENTITY=
# Optional: entity exposing friends online (list attribute or comma-separated state)
HA_PS5_FRIENDS_ENTITY=
# Optional: separate activity entity if your integration exposes one
HA_PS5_ACTIVITY_ENTITY=

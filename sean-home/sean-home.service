[Unit]
Description=Sean Home — TV dashboard
After=network.target

[Service]
Type=simple
User=sean
Group=sean
WorkingDirectory=/home/sean/sean-home
ExecStart=/home/sean/sean-home/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8088
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
